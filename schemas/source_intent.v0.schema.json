{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kirchherr/TUC/schemas/source_intent.v0.schema.json",
  "title": "TUC Source Intent v0",
  "description": "Schema-versioned plain-data contract for canonical Source Intent IR.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "schema_version", "tensors", "operations"],
  "properties": {
    "name": {"$ref": "#/$defs/identifier"},
    "schema_version": {"const": "source_intent.v0"},
    "tensors": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {"$ref": "#/$defs/tensor"}
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {"$ref": "#/$defs/operation"}
    },
    "returns": {
      "type": "array",
      "maxItems": 4096,
      "items": {"$ref": "#/$defs/return"}
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "dtype": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
    },
    "dimension": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647
    },
    "tensor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "shape"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "shape": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {"$ref": "#/$defs/dimension"}
        },
        "dtype": {"$ref": "#/$defs/dtype", "default": "float32"}
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "family", "inputs", "outputs"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "family": {
          "type": "string",
          "enum": ["elementwise", "matmul", "reduction", "softmax"]
        },
        "inputs": {"$ref": "#/$defs/tensor_name_list"},
        "outputs": {"$ref": "#/$defs/tensor_name_list"},
        "hints": {"$ref": "#/$defs/hints", "default": {}}
      }
    },
    "return": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_name", "tensor_name"],
      "properties": {
        "public_name": {"$ref": "#/$defs/identifier"},
        "tensor_name": {"$ref": "#/$defs/identifier"},
        "required": {"type": "boolean", "default": true}
      }
    },
    "tensor_name_list": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {"$ref": "#/$defs/identifier"}
    },
    "hints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prefer_linear_accelerator": {"type": "boolean", "default": false},
        "prefer_sparsity": {"type": "boolean", "default": false},
        "robust_to_noise": {"type": "boolean", "default": false},
        "max_error_budget": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
