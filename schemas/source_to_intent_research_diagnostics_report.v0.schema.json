{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kirchherr/TUC/schemas/source_to_intent_research_diagnostics_report.v0.schema.json",
  "title": "TUC Source-To-Intent Research Diagnostics Report v0",
  "description": "Source-free diagnostic report schema for the explicit execution-free Source-to-Intent research parser slice.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "accepted_case_count",
    "blocked_compiler_outputs",
    "blocked_execution_surfaces",
    "cases",
    "default_parser_status",
    "diagnostics_contract",
    "output_policy",
    "parser_contract",
    "parser_status",
    "raw_source_policy",
    "rejected_case_count",
    "rejection_reasons",
    "schema_version",
    "source_intent_schema_version"
  ],
  "properties": {
    "accepted_case_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 32
    },
    "blocked_compiler_outputs": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {"$ref": "#/$defs/report_text"}
    },
    "blocked_execution_surfaces": {
      "type": "array",
      "minItems": 14,
      "maxItems": 14,
      "items": {"$ref": "#/$defs/report_text"}
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {"$ref": "#/$defs/case"}
    },
    "default_parser_status": {"const": "default_parser_blocked"},
    "diagnostics_contract": {
      "const": "source_to_intent_research_diagnostics.execution_free.v0"
    },
    "output_policy": {"const": "source_intent.v0_plain_data_only"},
    "parser_contract": {
      "const": "source_to_intent_research_parser.execution_free.v0"
    },
    "parser_status": {"const": "research_explicit_only"},
    "raw_source_policy": {"const": "omitted_by_policy"},
    "rejected_case_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 32
    },
    "rejection_reasons": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "enum": [
          "missing_axis_keyword",
          "preflight_decorator_call",
          "preflight_import_statement",
          "unsupported_assignment_value"
        ]
      },
      "uniqueItems": true
    },
    "schema_version": {
      "const": "tuc.source_to_intent_research_diagnostics_report.v0"
    },
    "source_intent_schema_version": {"const": "source_intent.v0"}
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "expectation",
        "operation_families",
        "outcome",
        "parser_report_digest",
        "rejection_reason",
        "source_bytes",
        "source_digest",
        "source_name"
      ],
      "properties": {
        "case_id": {"$ref": "#/$defs/report_text"},
        "expectation": {"enum": ["accepted", "rejected"]},
        "operation_families": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "enum": ["elementwise", "matmul", "reduction", "softmax"]
          },
          "uniqueItems": true
        },
        "outcome": {"enum": ["accepted", "rejected"]},
        "parser_report_digest": {
          "oneOf": [
            {"const": ""},
            {"$ref": "#/$defs/sha256_digest"}
          ]
        },
        "rejection_reason": {
          "oneOf": [
            {"const": ""},
            {
              "enum": [
                "missing_axis_keyword",
                "preflight_decorator_call",
                "preflight_import_statement",
                "unsupported_assignment_value"
              ]
            }
          ]
        },
        "source_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65536
        },
        "source_digest": {"$ref": "#/$defs/sha256_digest"},
        "source_name": {"$ref": "#/$defs/identifier"}
      }
    },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
      "maxLength": 256
    },
    "report_text": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]+$",
      "minLength": 1,
      "maxLength": 256
    },
    "sha256_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
