{
  "$id": "https://tuc.dev/schemas/runtime_backend_equivalence_report.v0.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_status": {
      "const": "review_evidence"
    },
    "baseline_run_id": {
      "$ref": "#/$defs/report_text"
    },
    "blocked_execution_surfaces": {
      "items": false,
      "maxItems": 8,
      "minItems": 8,
      "prefixItems": [
        {
          "const": "backend_plugin_discovery"
        },
        {
          "const": "device_access"
        },
        {
          "const": "dynamic_import"
        },
        {
          "const": "dynamic_library_loading"
        },
        {
          "const": "generated_artifact_execution"
        },
        {
          "const": "jit_execution"
        },
        {
          "const": "network_access"
        },
        {
          "const": "subprocess_execution"
        }
      ],
      "type": "array"
    },
    "candidate_run_id": {
      "$ref": "#/$defs/report_text"
    },
    "comparison_count": {
      "maximum": 4096,
      "minimum": 1,
      "type": "integer"
    },
    "comparison_metadata_digest": {
      "$ref": "#/$defs/sha256_digest"
    },
    "comparisons": {
      "items": {
        "$ref": "#/$defs/comparison"
      },
      "maxItems": 4096,
      "minItems": 1,
      "type": "array"
    },
    "equivalence_contract": {
      "const": "runtime_backend_equivalence.data_only.v0"
    },
    "executor_contract": {
      "const": "runtime_executor.trusted_backend.v0"
    },
    "graph_name": {
      "$ref": "#/$defs/report_text"
    },
    "issues": {
      "items": {
        "$ref": "#/$defs/issue"
      },
      "maxItems": 256,
      "type": "array"
    },
    "passed": {
      "type": "boolean"
    },
    "raw_value_policy": {
      "const": "omitted_by_policy"
    },
    "run_count": {
      "const": 2
    },
    "runs": {
      "items": {
        "$ref": "#/$defs/run"
      },
      "maxItems": 2,
      "minItems": 2,
      "type": "array"
    },
    "schema_version": {
      "const": "tuc.runtime_backend_equivalence_report.v0"
    },
    "trusted_executor_registry": {
      "const": "trusted_runtime_executor_registry.v0"
    }
  },
  "required": [
    "artifact_status",
    "baseline_run_id",
    "blocked_execution_surfaces",
    "candidate_run_id",
    "comparison_count",
    "comparison_metadata_digest",
    "comparisons",
    "equivalence_contract",
    "executor_contract",
    "graph_name",
    "issues",
    "passed",
    "raw_value_policy",
    "run_count",
    "runs",
    "schema_version",
    "trusted_executor_registry"
  ],
  "type": "object",
  "$defs": {
    "comparison": {
      "additionalProperties": false,
      "properties": {
        "atol": {
          "$ref": "#/$defs/tolerance"
        },
        "baseline_dtype": {
          "$ref": "#/$defs/dtype_or_status"
        },
        "baseline_output_value_status": {
          "const": "omitted_by_policy"
        },
        "baseline_run_id": {
          "$ref": "#/$defs/report_text"
        },
        "baseline_shape": {
          "$ref": "#/$defs/optional_shape"
        },
        "candidate_dtype": {
          "$ref": "#/$defs/dtype_or_status"
        },
        "candidate_output_value_status": {
          "const": "omitted_by_policy"
        },
        "candidate_run_id": {
          "$ref": "#/$defs/report_text"
        },
        "candidate_shape": {
          "$ref": "#/$defs/optional_shape"
        },
        "comparison_status": {
          "$ref": "#/$defs/comparison_status"
        },
        "expected_dtype": {
          "$ref": "#/$defs/concrete_dtype"
        },
        "expected_shape": {
          "$ref": "#/$defs/shape"
        },
        "rtol": {
          "$ref": "#/$defs/tolerance"
        },
        "tensor_name": {
          "$ref": "#/$defs/report_text"
        }
      },
      "required": [
        "atol",
        "baseline_dtype",
        "baseline_output_value_status",
        "baseline_run_id",
        "baseline_shape",
        "candidate_dtype",
        "candidate_output_value_status",
        "candidate_run_id",
        "candidate_shape",
        "comparison_status",
        "expected_dtype",
        "expected_shape",
        "rtol",
        "tensor_name"
      ],
      "type": "object"
    },
    "comparison_status": {
      "enum": [
        "invalid_baseline_output",
        "invalid_candidate_output",
        "matched",
        "mismatched",
        "missing_baseline_output",
        "missing_candidate_output"
      ]
    },
    "concrete_dtype": {
      "allOf": [
        {
          "$ref": "#/$defs/report_text"
        },
        {
          "not": {
            "enum": [
              "invalid",
              "missing"
            ]
          }
        }
      ]
    },
    "dtype_or_status": {
      "anyOf": [
        {
          "$ref": "#/$defs/report_text"
        },
        {
          "enum": [
            "invalid",
            "missing"
          ]
        }
      ]
    },
    "issue": {
      "additionalProperties": false,
      "properties": {
        "issue_code": {
          "$ref": "#/$defs/report_text"
        },
        "subject": {
          "$ref": "#/$defs/report_text"
        }
      },
      "required": [
        "issue_code",
        "subject"
      ],
      "type": "object"
    },
    "optional_shape": {
      "items": {
        "maximum": 2147483647,
        "minimum": 1,
        "type": "integer"
      },
      "maxItems": 8,
      "type": "array"
    },
    "report_text": {
      "maxLength": 512,
      "not": {
        "enum": [
          "backend_artifact",
          "callable",
          "command",
          "device_id",
          "dynamic_library",
          "env",
          "environment",
          "executable",
          "file_path",
          "generated_code",
          "host_path",
          "import_module",
          "jit_function",
          "module",
          "network",
          "output_value",
          "plugin_entrypoint",
          "python_module",
          "python_source",
          "raw_benchmark_output",
          "raw_tensor_value",
          "raw_timing_samples",
          "reference_value",
          "source_text",
          "subprocess",
          "tensor_value",
          "url"
        ]
      },
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "type": "string"
    },
    "run": {
      "additionalProperties": false,
      "properties": {
        "execution_status": {
          "const": "executed"
        },
        "graph_name": {
          "$ref": "#/$defs/report_text"
        },
        "output_metadata_digest": {
          "$ref": "#/$defs/sha256_digest"
        },
        "output_tensor_names": {
          "items": {
            "$ref": "#/$defs/report_text"
          },
          "maxItems": 4096,
          "minItems": 1,
          "type": "array"
        },
        "output_value_status": {
          "const": "omitted_by_policy"
        },
        "planned_backend_sequence": {
          "items": {
            "$ref": "#/$defs/report_text"
          },
          "maxItems": 4096,
          "minItems": 1,
          "type": "array"
        },
        "run_id": {
          "$ref": "#/$defs/report_text"
        },
        "tensor_record_count": {
          "maximum": 4096,
          "minimum": 1,
          "type": "integer"
        },
        "trace_step_count": {
          "maximum": 4096,
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "execution_status",
        "graph_name",
        "output_metadata_digest",
        "output_tensor_names",
        "output_value_status",
        "planned_backend_sequence",
        "run_id",
        "tensor_record_count",
        "trace_step_count"
      ],
      "type": "object"
    },
    "sha256_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "shape": {
      "items": {
        "maximum": 2147483647,
        "minimum": 1,
        "type": "integer"
      },
      "maxItems": 8,
      "minItems": 1,
      "type": "array"
    },
    "tolerance": {
      "maximum": 1,
      "minimum": 0,
      "type": "number"
    }
  }
}
