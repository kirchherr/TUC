{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kirchherr/TUC/schemas/workload_scope_report.v0.schema.json",
  "title": "TUC Workload Scope Report v0",
  "description": "Diagnostic-only schema for future performance workload scope review. This is not a native performance proof.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_status",
    "claim_boundary",
    "issues",
    "native_performance_claim",
    "performance_claim_status",
    "proposal_name",
    "schema_version",
    "scopes",
    "workload_scope_ready"
  ],
  "properties": {
    "artifact_status": {"const": "diagnostic_only"},
    "claim_boundary": {"const": "performance_proof_boundary.blocking.v0"},
    "issues": {
      "type": "array",
      "maxItems": 128,
      "items": {"$ref": "#/$defs/report_text"}
    },
    "native_performance_claim": {"const": false},
    "performance_claim_status": {"const": "blocked"},
    "proposal_name": {"$ref": "#/$defs/report_text"},
    "schema_version": {"const": "tuc.workload_scope_report.v0"},
    "scopes": {
      "type": "array",
      "maxItems": 128,
      "items": {"$ref": "#/$defs/workload_scope"}
    },
    "workload_scope_ready": {"type": "boolean"}
  },
  "$defs": {
    "operation_family": {
      "type": "string",
      "enum": ["matmul", "elementwise", "reduction", "softmax"]
    },
    "problem_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000000000000
    },
    "report_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$"
    },
    "workload_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correctness_reference_id",
        "dtype_policy_id",
        "operation_family",
        "problem_size_max",
        "problem_size_min",
        "scope_id",
        "shape_profile_id"
      ],
      "properties": {
        "correctness_reference_id": {"$ref": "#/$defs/report_text"},
        "dtype_policy_id": {"$ref": "#/$defs/report_text"},
        "operation_family": {"$ref": "#/$defs/operation_family"},
        "problem_size_max": {"$ref": "#/$defs/problem_size"},
        "problem_size_min": {"$ref": "#/$defs/problem_size"},
        "scope_id": {"$ref": "#/$defs/report_text"},
        "shape_profile_id": {"$ref": "#/$defs/report_text"}
      }
    }
  }
}
