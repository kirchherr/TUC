{
  "$id": "https://tuc.dev/schemas/runtime_backend_equivalence_portfolio_policy_report.v0.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_status": {
      "const": "review_evidence"
    },
    "blocked_execution_surfaces": {
      "items": false,
      "maxItems": 8,
      "minItems": 8,
      "prefixItems": [
        {
          "const": "backend_plugin_discovery"
        },
        {
          "const": "device_access"
        },
        {
          "const": "dynamic_import"
        },
        {
          "const": "dynamic_library_loading"
        },
        {
          "const": "generated_artifact_execution"
        },
        {
          "const": "jit_execution"
        },
        {
          "const": "network_access"
        },
        {
          "const": "subprocess_execution"
        }
      ],
      "type": "array"
    },
    "policy_contract": {
      "const": "runtime_backend_equivalence_portfolio_policy.data_only.v0"
    },
    "policy_id": {
      "const": "runtime_backend_equivalence_portfolio_policy"
    },
    "policy_metadata_digest": {
      "$ref": "#/$defs/sha256_digest"
    },
    "policy_status": {
      "const": "accepted"
    },
    "portfolio_id": {
      "$ref": "#/$defs/report_text"
    },
    "raw_value_policy": {
      "const": "omitted_by_policy"
    },
    "required_candidate_backend_families": {
      "items": {
        "$ref": "#/$defs/report_text"
      },
      "maxItems": 16,
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "requirement_count": {
      "maximum": 16,
      "minimum": 1,
      "type": "integer"
    },
    "requirements": {
      "items": {
        "$ref": "#/$defs/requirement"
      },
      "maxItems": 16,
      "minItems": 1,
      "type": "array"
    },
    "schema_version": {
      "const": "tuc.runtime_backend_equivalence_portfolio_policy_report.v0"
    },
    "trusted_executor_registry": {
      "const": "trusted_runtime_executor_registry.v0"
    }
  },
  "required": [
    "artifact_status",
    "blocked_execution_surfaces",
    "policy_contract",
    "policy_id",
    "policy_metadata_digest",
    "policy_status",
    "portfolio_id",
    "raw_value_policy",
    "required_candidate_backend_families",
    "requirement_count",
    "requirements",
    "schema_version",
    "trusted_executor_registry"
  ],
  "type": "object",
  "$defs": {
    "backend_sequence": {
      "items": {
        "$ref": "#/$defs/report_text"
      },
      "maxItems": 4096,
      "minItems": 1,
      "type": "array"
    },
    "report_text": {
      "maxLength": 512,
      "not": {
        "enum": [
          "backend_artifact",
          "callable",
          "command",
          "command_line",
          "device_id",
          "dynamic_library",
          "env",
          "environment",
          "executable",
          "file_path",
          "generated_code",
          "host_path",
          "import_module",
          "jit_function",
          "module",
          "network",
          "output_value",
          "plugin_entrypoint",
          "python_module",
          "python_source",
          "raw_benchmark_output",
          "raw_tensor_value",
          "raw_timing_samples",
          "reference_value",
          "runtime_handle",
          "source_text",
          "subprocess",
          "tensor_value",
          "tensor_values",
          "url"
        ]
      },
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "type": "string"
    },
    "requirement": {
      "additionalProperties": false,
      "properties": {
        "baseline_backend_sequence": {
          "$ref": "#/$defs/backend_sequence"
        },
        "baseline_run_id": {
          "$ref": "#/$defs/report_text"
        },
        "candidate_backend_sequence": {
          "$ref": "#/$defs/backend_sequence"
        },
        "candidate_run_id": {
          "$ref": "#/$defs/report_text"
        },
        "graph_name": {
          "$ref": "#/$defs/report_text"
        },
        "min_comparison_count": {
          "maximum": 4096,
          "minimum": 1,
          "type": "integer"
        },
        "slice_id": {
          "$ref": "#/$defs/report_text"
        }
      },
      "required": [
        "baseline_backend_sequence",
        "baseline_run_id",
        "candidate_backend_sequence",
        "candidate_run_id",
        "graph_name",
        "min_comparison_count",
        "slice_id"
      ],
      "type": "object"
    },
    "sha256_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  }
}
